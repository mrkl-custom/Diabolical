<Window x:Class="Diabolical.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diabolical" Height="480" Width="820">
    <DockPanel Margin="16">

        <GroupBox Header="Character" DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="8">
                <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CharacterComboBox" Width="160" IsEditable="True"
                          SelectionChanged="CharacterComboBox_SelectionChanged"/>
                <TextBlock Text="Class:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <TextBox x:Name="ClassTextBox" Width="120"/>
                <Button x:Name="SwitchCharacterButton" Content="Switch / Create" Margin="16,0,0,0"
                        Click="SwitchCharacterButton_Click"/>
            </StackPanel>
        </GroupBox>

        <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <GroupBox Header="Vision Provider" DockPanel.Dock="Right" Margin="12,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="8">
                    <Ellipse x:Name="ProviderStatusDot" Width="12" Height="12" Fill="Gray" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProviderStatusText" Text="Checking..." VerticalAlignment="Center"/>
                    <Button x:Name="RecheckProviderButton" Content="Recheck" Margin="8,0,0,0" Click="RecheckProviderButton_Click"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Export">
                <StackPanel Orientation="Horizontal" Margin="8">
                    <Button x:Name="CopyJsonButton" Content="Copy JSON to Clipboard" Width="180" Margin="0,0,8,0"
                            Click="CopyJsonButton_Click"/>
                    <Button x:Name="ExportFileButton" Content="Export to File..." Width="150"
                            Click="ExportFileButton_Click"/>
                </StackPanel>
            </GroupBox>
        </DockPanel>

        <GroupBox Header="Status" DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <ListBox x:Name="StatusList" Height="100" Margin="4"/>
        </GroupBox>

        <GroupBox Header="Equipment">
            <DataGrid x:Name="EquipmentDataGrid" Margin="4" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Slot" Width="100" Binding="{Binding Slot}"/>
                    <DataGridTextColumn Header="Name" Width="*" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Rarity" Width="90" Binding="{Binding Rarity}"/>
                    <DataGridTextColumn Header="Quality" Width="90" Binding="{Binding Quality}"/>
                    <DataGridTextColumn Header="Item Power" Width="90" Binding="{Binding ItemPower}"/>
                    <DataGridTemplateColumn Header="" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="View" Padding="6,2" Tag="{Binding}" Click="ViewEquipmentButton_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove" Padding="6,2" Tag="{Binding}" Click="RemoveEquipmentButton_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </DockPanel>
</Window>
