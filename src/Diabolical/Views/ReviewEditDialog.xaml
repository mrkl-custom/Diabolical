<Window x:Class="Diabolical.Views.ReviewEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Review Item" Height="480" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Slot" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="SlotTextBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Name" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Rarity" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="RarityComboBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Item Power" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="ItemPowerTextBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Aspect" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="AspectTextBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/>

        <TextBlock Text="Affixes (one per line)" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,4"/>
        <TextBox x:Name="AffixesTextBox" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="DiscardButton" Content="Discard" Width="90" Margin="0,0,8,0" Click="DiscardButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="90" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
